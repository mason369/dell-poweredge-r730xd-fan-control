<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="DellR730xdFanControlCenter.Controls.DashboardSensorIcon"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AutomationProperties.AccessibilityView="Raw"
    IsTabStop="False">
    <Grid Width="24" Height="24">
        <Grid x:Name="IconLayer">
            <Ellipse
                x:Name="OuterRing"
                Width="22"
                Height="22"
                Opacity="0.28"
                Stroke="{Binding EffectiveAccentBrush, ElementName=Root}"
                StrokeThickness="1.25" />

            <Grid x:Name="TemperatureGroup" Visibility="Collapsed">
                <Path
                    Data="M10,4 A2,2 0 0 1 14,4 L14,13 A5,5 0 1 1 10,13 Z"
                    Stroke="{Binding EffectiveAccentBrush, ElementName=Root}"
                    StrokeThickness="1.65" />
                <Rectangle
                    x:Name="TemperatureLevel"
                    Width="2.6"
                    Height="10"
                    Margin="0,0,0,4.2"
                    VerticalAlignment="Bottom"
                    Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
                <Ellipse Width="5.2" Height="5.2" Margin="0,0,0,2.9" VerticalAlignment="Bottom" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
            </Grid>

            <Grid x:Name="FanGroup" Visibility="Collapsed">
                <Grid
                    x:Name="FanRotor"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Path
                        Data="M12,3 C13.8,3 15,4.2 15,6 C15,8.1 13.8,9.7 12.5,10.7 C12.2,10.5 11.8,10.5 11.5,10.7 C10.2,9.7 9,8.1 9,6 C9,4.2 10.2,3 12,3 Z M21,12 C21,13.8 19.8,15 18,15 C15.9,15 14.3,13.8 13.3,12.5 C13.5,12.2 13.5,11.8 13.3,11.5 C14.3,10.2 15.9,9 18,9 C19.8,9 21,10.2 21,12 Z M12,21 C10.2,21 9,19.8 9,18 C9,15.9 10.2,14.3 11.5,13.3 C11.8,13.5 12.2,13.5 12.5,13.3 C13.8,14.3 15,15.9 15,18 C15,19.8 13.8,21 12,21 Z M3,12 C3,10.2 4.2,9 6,9 C8.1,9 9.7,10.2 10.7,11.5 C10.5,11.8 10.5,12.2 10.7,12.5 C9.7,13.8 8.1,15 6,15 C4.2,15 3,13.8 3,12 Z M12,9.7 A2.3,2.3 0 1 1 12,14.3 A2.3,2.3 0 0 1 12,9.7 Z"
                        Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
                </Grid>
            </Grid>

            <Grid x:Name="CpuUsageGroup" Visibility="Collapsed">
                <Rectangle
                    x:Name="CpuUsageLevel"
                    Width="9"
                    Height="9"
                    Opacity="0.3"
                    Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
                <Path Data="M7,7 H17 V17 H7 Z M9.5,9.5 H14.5 V14.5 H9.5 Z" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.55" />
                <Path Data="M8,4 V7 M12,4 V7 M16,4 V7 M8,17 V20 M12,17 V20 M16,17 V20 M4,8 H7 M4,12 H7 M4,16 H7 M17,8 H20 M17,12 H20 M17,16 H20" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.35" />
            </Grid>

            <Grid x:Name="MemoryUsageGroup" Visibility="Collapsed">
                <Rectangle x:Name="MemoryUsageLevel" Width="14" Height="9" Margin="0,0,0,1" VerticalAlignment="Bottom" Opacity="0.3" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
                <Path Data="M5,7 H19 V17 H5 Z M8,9 V14 M12,9 V14 M16,9 V14 M7,17 V20 M10,17 V20 M14,17 V20 M17,17 V20" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.55" />
            </Grid>

            <Grid x:Name="IoUsageGroup" Visibility="Collapsed">
                <Rectangle x:Name="IoUsageLevel" Width="13" Height="12" Opacity="0.25" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
                <Path Data="M5,8 H15 M12,5 L15,8 L12,11 M19,16 H9 M12,13 L9,16 L12,19" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.8" />
            </Grid>

            <Grid x:Name="SystemUsageGroup" Visibility="Collapsed">
                <Rectangle x:Name="SystemUsageLevel" Width="14" Height="13" Margin="0,0,0,3" VerticalAlignment="Bottom" Opacity="0.25" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
                <Path Data="M5,5 H19 V16 H5 Z M8,19 H16 M12,16 V19 M8,12 V14 M11,9 V14 M14,7 V14 M17,10 V14" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.5" />
            </Grid>

            <Grid x:Name="PowerGroup" Visibility="Collapsed">
                <Path x:Name="PowerActivityElement" Data="M13,2 L5,13 H10 L8.5,22 L19,9.5 H13 Z" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
            </Grid>

            <Grid x:Name="VoltageGroup" Visibility="Collapsed">
                <Path Data="M5.5,16 A7.5,7.5 0 0 1 18.5,16 M7.5,18 H16.5" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.7" />
                <Path x:Name="VoltageNeedle" Data="M12,15 L12,7.5" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="2" />
                <Ellipse Width="3.4" Height="3.4" Margin="0,6,0,0" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
            </Grid>

            <Grid x:Name="CurrentGroup" Visibility="Collapsed">
                <Path Data="M5,12 C7,7.5 10,7.5 12,12 C14,16.5 17,16.5 19,12 M16,9 L19,12 L16,15" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.75" />
                <Ellipse x:Name="CurrentFlowMarker" Width="3.4" Height="3.4" HorizontalAlignment="Left" Margin="4,0,0,0" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
            </Grid>

            <Grid x:Name="IntrusionGroup" Visibility="Collapsed">
                <Path Data="M6,4 H16 V20 H6 Z M9,7 H16 M13,13 H13.1" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.7" />
                <Path Data="M17,7 L21,14 H13 Z" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.35" />
            </Grid>

            <Grid x:Name="FanRedundancyGroup" Visibility="Collapsed">
                <Path Data="M8,5 C10,5 10,8 8.8,9 C11,8.5 12.5,11 11,12 C9.8,13 8,11 8.2,9.5 C7.3,11 4.5,10.5 5,8.5 C5.5,6.8 7,7.5 8,8.5 Z M16,12 C18,12 18,15 16.8,16 C19,15.5 20.5,18 19,19 C17.8,20 16,18 16.2,16.5 C15.3,18 12.5,17.5 13,15.5 C13.5,13.8 15,14.5 16,15.5 Z" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
            </Grid>

            <Grid x:Name="PowerRedundancyGroup" Visibility="Collapsed">
                <Path Data="M5,6 H11 V13 H5 Z M13,11 H19 V18 H13 Z M7,3 V6 M9,3 V6 M15,8 V11 M17,8 V11 M8,13 V17 H13" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.55" />
            </Grid>

            <Grid x:Name="CmosBatteryGroup" Visibility="Collapsed">
                <Ellipse Width="14" Height="14" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.7" />
                <Path Data="M12,8 V16 M8,12 H16" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.6" />
            </Grid>

            <Grid x:Name="RombBatteryGroup" Visibility="Collapsed">
                <Path Data="M5,7 H18 V17 H5 Z M18,10 H20 V14 H18 M8,10 H15 M8,14 H13" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.65" />
            </Grid>

            <Grid x:Name="UsbOverCurrentGroup" Visibility="Collapsed">
                <Path Data="M12,19 V7 M12,7 L9,10 M12,7 L15,10 M12,12 H7 V9 M12,15 H17 V12" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.65" />
                <Path Data="M17,4 L21,10 H13 Z M17,6 V8" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.25" />
            </Grid>

            <Grid x:Name="PowerPolicyGroup" Visibility="Collapsed">
                <Path Data="M5,7 H19 M5,12 H19 M5,17 H19" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.5" />
                <Ellipse Width="4" Height="4" Margin="-7,-5,0,0" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
                <Ellipse Width="4" Height="4" Margin="7,5,0,0" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
                <Ellipse Width="4" Height="4" Margin="-3,15,0,0" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
            </Grid>

            <Grid x:Name="StorageDriveGroup" Visibility="Collapsed">
                <Path Data="M5,6 H19 V18 H5 Z M7,9 H17 M7,13 H14" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.65" />
                <Ellipse Width="3" Height="3" Margin="11,9,0,0" Fill="{Binding EffectiveAccentBrush, ElementName=Root}" />
            </Grid>

            <Grid x:Name="RaidControllerGroup" Visibility="Collapsed">
                <Path Data="M5,5 H19 V19 H5 Z M8,8 H16 V12 H8 Z M8,16 H8.1 M12,16 H12.1 M16,16 H16.1" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.65" />
            </Grid>

            <Grid x:Name="StorageCacheGroup" Visibility="Collapsed">
                <Path Data="M5,7 H17 V15 H5 Z M7,10 H15 M7,13 H13 M18,9 V17 H7" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.65" />
                <Path Data="M15,4 L19,4 L19,8" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.65" />
            </Grid>

            <Grid x:Name="GenericStatusGroup" Visibility="Collapsed">
                <Ellipse Width="15" Height="15" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.7" />
                <Path Data="M12,10 V16 M12,7.2 V7.3" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.9" />
            </Grid>
        </Grid>

        <Grid x:Name="NormalBadgeGroup" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="Collapsed">
            <Ellipse Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
            <Path Data="M2,4 L3.4,5.4 L6.2,2.5" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
        </Grid>
        <Grid x:Name="InformationBadgeGroup" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="Collapsed">
            <Ellipse Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
            <Path Data="M4,3.4 V6 M4,1.8 V1.9" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
        </Grid>
        <Grid x:Name="InactiveBadgeGroup" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="Collapsed">
            <Ellipse Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
            <Path Data="M2,4 H6" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
        </Grid>
        <Grid x:Name="UnavailableBadgeGroup" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="Collapsed">
            <Ellipse Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
            <Path Data="M2.7,2.6 C2.7,1.7 3.3,1.2 4.2,1.2 C5.1,1.2 5.7,1.8 5.7,2.6 C5.7,3.4 5.1,3.8 4.4,4.3 V4.8 M4.4,6 V6.1" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1" />
        </Grid>
        <Grid x:Name="WarningBadgeGroup" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="Collapsed">
            <Path Data="M4,0.8 L7.3,6.8 H0.7 Z" Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1" />
            <Path Data="M4,2.7 V4.8 M4,5.8 V5.9" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1" />
        </Grid>
        <Grid x:Name="CriticalBadgeGroup" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="Collapsed">
            <Ellipse Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
            <Path Data="M4,1.7 V4.9 M4,6.2 V6.3" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
        </Grid>
        <Grid x:Name="StaleBadgeGroup" Width="8" Height="8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="Collapsed">
            <Ellipse Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.2" />
            <Path Data="M4,2 V4 L5.6,5" Stroke="{Binding EffectiveAccentBrush, ElementName=Root}" StrokeThickness="1.05" />
        </Grid>
    </Grid>
</UserControl>
