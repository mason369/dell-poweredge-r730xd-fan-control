                                                            local:Localization.Key="Preset.SmoothCurve" />
                                                        <TextBlock
                                                            Style="{StaticResource MutedTextStyle}"
                                                            Text="{Binding CurvePreviewHeader}" />
                                                        <TextBlock
                                                            FontFamily="Consolas"
                                                            Style="{StaticResource MutedTextStyle}"
                                                            Text="{Binding CurveChartText}"
                                                            TextWrapping="Wrap" />
