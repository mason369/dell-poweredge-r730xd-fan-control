                                                        Minimum="0"
                                                        SmallChange="10"
                                                        SpinButtonPlacementMode="Compact"
                                                        Value="500" />
                                                    <NumberBox
                                                        x:Name="NewPowerCurvePercentBox"
                                                        Grid.Column="1"
                                                        Header="风扇 %"
