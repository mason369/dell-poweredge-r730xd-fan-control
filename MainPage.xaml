<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DellR730xdFanControlCenter.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DellR730xdFanControlCenter"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnPageLoaded"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
    </Page.Resources>

    <NavigationView
        x:Name="ShellNavigation"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        PaneDisplayMode="LeftCompact"
        SelectionChanged="OnNavigationSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="总览 Overview" IsSelected="True" Tag="Overview">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="风扇 Fan Control" Tag="Control">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE9CA;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="传感器 Sensors" Tag="Sensors">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE7B5;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="设置 Settings" Tag="Settings">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <InfoBar
                x:Name="StatusInfoBar"
                Margin="24,12,24,0"
                IsClosable="True"
                IsOpen="False"
                Severity="Informational" />

            <ScrollViewer Grid.Row="1">
                <StackPanel Padding="24" Spacing="18">
                    <Border
                        MinHeight="156"
                        Padding="24"
                        CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#213448" Offset="0" />
                                <GradientStop Color="#0E766E" Offset="0.55" />
                                <GradientStop Color="#A16207" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Text="Dell R730xd iDRAC Fan Control Center" />
                                <TextBlock
                                    Foreground="White"
                                    FontSize="32"
                                    FontWeight="SemiBold"
                                    Text="R730XD 智控风扇中心" />
                                <TextBlock
                                    MaxWidth="780"
                                    Foreground="#DDEFFF"
                                    Text="监控 BMC 传感器，控制全部或单个风扇，支持 Dell 自动模式与软件恒温策略。" />
                            </StackPanel>
                            <StackPanel
                                Grid.Column="1"
                                MinWidth="230"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <TextBlock
                                    Foreground="#DDEFFF"
                                    Text="当前目标 / Current target" />
                                <TextBlock
                                    x:Name="CurrentTargetText"
                                    Foreground="White"
                                    FontSize="20"
                                    FontWeight="SemiBold"
                                    Text="192.168.1.73" />
                                <TextBlock
                                    x:Name="ConnectionStateText"
                                    Foreground="#DDEFFF"
                                    Text="未连接 / Not connected" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid x:Name="OverviewView">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,12,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="最高 CPU 温度 / Max CPU temp" />
                                <TextBlock x:Name="CpuTemperatureText" Style="{StaticResource MetricValueStyle}" Text="-- °C" />
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="来自 SDR 温度传感器" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Margin="6,0,6,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="风扇状态 / Fan status" />
                                <TextBlock x:Name="FanSummaryText" Style="{StaticResource MetricValueStyle}" Text="6 fans" />
                                <TextBlock x:Name="FanRpmSummaryText" Style="{StaticResource MutedTextStyle}" Text="等待刷新 / Waiting refresh" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Margin="12,0,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="控制模式 / Mode" />
                                <TextBlock x:Name="ModeSummaryText" Style="{StaticResource MetricValueStyle}" Text="Idle" />
                                <TextBlock x:Name="AutoPolicySummaryText" Style="{StaticResource MutedTextStyle}" Text="软件自动策略未运行" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="14">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="快速操作 / Quick Actions" />
                                    <CommandBar DefaultLabelPosition="Right" IsOpen="False">
                                        <AppBarButton
                                            Click="OnTestConnectionClick"
                                            Icon="Contact"
                                            Label="测试连接" />
                                        <AppBarButton
                                            Click="OnRefreshSensorsClick"
                                            Icon="Refresh"
                                            Label="刷新传感器" />
                                        <AppBarButton
                                            Click="OnRestoreDefaultClick"
                                            Icon="Sync"
                                            Label="还原 10%" />
                                        <AppBarButton
                                            Click="OnVisitIdracClick"
                                            Icon="World"
                                            Label="打开 iDRAC" />
                                    </CommandBar>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="全部风扇 / All Fans" />
                                    <Slider
                                        x:Name="AllFanSlider"
                                        Maximum="100"
                                        Minimum="0"
                                        StepFrequency="1"
                                        ValueChanged="OnAllFanSliderChanged" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <NumberBox
                                            x:Name="AllFanPercentBox"
                                            Grid.Column="1"
                                            Maximum="100"
                                            Minimum="0"
                                            SmallChange="1"
                                            SpinButtonPlacementMode="Inline"
                                            ValueChanged="OnAllFanNumberChanged" />
                                        <Button Grid.Column="2" Click="OnSetAllFansClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                                <TextBlock Text="应用 / Apply" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="10">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="软件恒温策略 / Smart Auto Policy" />
                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="按 CPU 温度线性调整全部风扇；达到紧急温度时切回 Dell 自动模式。" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="StartAutoButton" Click="OnStartAutoPolicyClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="14" Glyph="&#xE768;" />
                                                <TextBlock Text="启动自动 / Start" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            x:Name="StopAutoButton"
                                            Grid.Column="1"
                                            Click="OnStopAutoPolicyClick"
                                            IsEnabled="False">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="14" Glyph="&#xE71A;" />
                                                <TextBlock Text="停止 / Stop" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="最新日志 / Recent Log" />
                                    <ListView
                                        MaxHeight="220"
                                        ItemsSource="{x:Bind Logs, Mode=OneWay}"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64" />
                                                        <ColumnDefinition Width="72" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DisplayTime}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Level}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="ControlView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="16">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="预设模式 / Presets" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Click="OnRestoreDefaultClick">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="默认 Restore" />
                                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="手动 10%" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Click="OnPresetClick" Tag="20">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="均衡 Balanced" />
                                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="20%" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="2" Click="OnPresetClick" Tag="35">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="散热 Cooling" />
                                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="35%" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="3" Click="OnPresetClick" Tag="50">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="性能 Performance" />
                                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="50%" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="4" Click="OnResetAutoClick">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="Dell 自动 Auto" />
                                            <TextBlock Style="{StaticResource MutedTextStyle}" Text="BMC" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="单风扇控制 / Individual Fans" />
                                <InfoBar
                                    IsOpen="True"
                                    Severity="Warning"
                                    Message="单风扇 raw target 默认关闭。本机 R730XD/iDRAC 2.82 实测 0x00 target 会让全部风扇高转，启用前请确认你的固件映射。" />
                                <TextBlock Style="{StaticResource MutedTextStyle}" Text="启用后会发送 Dell OEM raw target byte：Fan 1-6 映射为 0x00-0x05。若行为不符合预期，请立即恢复 Dell 自动模式。" />
                                <ListView ItemsSource="{x:Bind FanChannels, Mode=OneWay}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,8" ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding ChineseName}" />
                                                </StackPanel>
                                                <Slider
                                                    Grid.Column="1"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    StepFrequency="1"
                                                    Value="{Binding Percent, Mode=TwoWay}" />
                                                <NumberBox
                                                    Grid.Column="2"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    SmallChange="1"
                                                    SpinButtonPlacementMode="Inline"
                                                    Value="{Binding Percent, Mode=TwoWay}" />
                                                <Button
                                                    Grid.Column="3"
                                                    Click="OnSetSingleFanClick"
                                                    Tag="{Binding Index}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                                        <TextBlock Text="设置 / Set" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="6">
                                    <TextBlock Text="目标温度 / Target" />
                                    <NumberBox x:Name="TargetTempBox" Maximum="95" Minimum="30" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="高温 / High" />
                                    <NumberBox x:Name="HighTempBox" Maximum="100" Minimum="40" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock Text="紧急自动 / Emergency" />
                                    <NumberBox x:Name="EmergencyTempBox" Maximum="105" Minimum="45" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="6">
                                    <TextBlock Text="轮询秒数 / Poll seconds" />
                                    <NumberBox x:Name="SensorRefreshSecondsBox" Maximum="300" Minimum="5" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="SensorsView" Visibility="Collapsed">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="BMC 传感器 / BMC Sensors" />
                                    <Button Grid.Column="1" Click="OnRefreshSensorsClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                            <TextBlock Text="刷新 / Refresh" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <ListView
                                    MaxHeight="640"
                                    ItemsSource="{x:Bind Sensors, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.Header>
                                        <Grid Padding="12,6" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="Key / 传感器" />
                                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Value / 读数" />
                                            <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="Unit / 单位" />
                                            <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Status / 状态" />
                                        </Grid>
                                    </ListView.Header>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="12,7" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Key}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" />
                                                <TextBlock Grid.Column="2" Text="{Binding Unit}" />
                                                <TextBlock Grid.Column="3" Text="{Binding Status}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="SettingsView" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,9,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="iDRAC 连接 / Connection" />
                                <TextBox x:Name="HostBox" Header="BMC/iDRAC IP" />
                                <TextBox x:Name="UserNameBox" Header="用户名 / Username" />
                                <PasswordBox
                                    x:Name="PasswordBox"
                                    Header="密码 / Password"
                                    PasswordRevealMode="Peek" />
                                <ToggleSwitch x:Name="RememberPasswordSwitch" Header="使用 DPAPI 保存密码 / Remember password with DPAPI" />
                                <TextBox x:Name="IpmiToolPathBox" Header="ipmitool.exe 路径 / ipmitool path" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Click="OnSaveSettingsClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                            <TextBlock Text="保存设置 / Save" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Click="OnTestConnectionClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE8FB;" />
                                            <TextBlock Text="测试 / Test" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock Style="{StaticResource SectionTitleStyle}" Text="应用设置 / Application" />
                                <ToggleSwitch x:Name="MinimizeToTraySwitch" Header="点击关闭时最小化到托盘 / Minimize to tray on close" />
                                <ToggleSwitch x:Name="IndividualFanSwitch" Header="启用单风扇 raw target / Enable individual fan targets" />
                                <NumberBox x:Name="FanCountBox" Header="风扇数量 / Fan count" Maximum="6" Minimum="1" SpinButtonPlacementMode="Inline" />
                                <NumberBox x:Name="CommandTimeoutBox" Header="命令超时秒数 / Command timeout seconds" Maximum="180" Minimum="5" SpinButtonPlacementMode="Inline" />
                                <NumberBox x:Name="AutoMinFanBox" Header="自动策略最小风扇百分比 / Auto min fan %" Maximum="100" Minimum="0" SpinButtonPlacementMode="Inline" />
                                <NumberBox x:Name="AutoMaxFanBox" Header="自动策略最大风扇百分比 / Auto max fan %" Maximum="100" Minimum="0" SpinButtonPlacementMode="Inline" />
                                <ComboBox x:Name="ThemeComboBox" Header="主题 / Theme">
                                    <ComboBoxItem Content="跟随系统 / System" Tag="Default" />
                                    <ComboBoxItem Content="浅色 / Light" Tag="Light" />
                                    <ComboBoxItem Content="深色 / Dark" Tag="Dark" />
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </NavigationView>
</Page>
