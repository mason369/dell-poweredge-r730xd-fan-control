                                <TextBox
                                    x:Name="IpmiToolPathBox"
                                    local:Localization.Key="Settings.BundledIpmiPath"
                                    Header="内置 ipmitool 路径"
                                    IsReadOnly="True" />
                            </StackPanel>
                        </Border>
                        <Border
                            x:Name="ApplicationSettingsCard"
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="9,0,0,0"
                            Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    local:Localization.Key="Settings.Application"
                                    Style="{StaticResource SectionTitleStyle}"
                                    Text="应用设置" />
                                <ToggleSwitch
                                    x:Name="MinimizeToTraySwitch"
                                    local:Localization.Key="Settings.MinimizeToTray"
                                    Header="点击关闭时最小化到托盘" />
                                <ToggleSwitch
                                    x:Name="IndividualFanSwitch"
                                    local:Localization.Key="Settings.EnableIndividualFanTargets"
                                    Header="启用单风扇目标编号控制"
                                    Toggled="OnIndividualFanSwitchToggled" />
                                <NumberBox
                                    x:Name="FanCountBox"
                                    local:Localization.Key="Settings.FanCount"
                                    Header="风扇数量"
                                    Maximum="6"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="CommandTimeoutBox"
                                    local:Localization.Key="Settings.CommandTimeout"
                                    Header="命令超时秒数"
                                    Maximum="180"
                                    Minimum="5"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="SensorRefreshSecondsBox"
                                    local:Localization.Key="Settings.SensorRefreshSeconds"
                                    Header="轮询秒数"
                                    Maximum="300"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="AutoMinFanBox"
                                    local:Localization.Key="Settings.AutoMinFan"
                                    Header="自动策略最小风扇百分比"
                                    Maximum="100"
                                    Minimum="0"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="AutoMaxFanBox"
                                    local:Localization.Key="Settings.AutoMaxFan"
                                    Header="自动策略最大风扇百分比"
                                    Maximum="100"
                                    Minimum="0"
                                    SpinButtonPlacementMode="Inline" />
                                <ComboBox
                                    x:Name="ThemeComboBox"
                                    local:Localization.Key="Settings.Theme"
                                    Header="主题">
                                    <ComboBoxItem
                                        local:Localization.Key="Theme.System"
                                        Content="跟随系统"
                                        Tag="Default" />
                                    <ComboBoxItem
                                        local:Localization.Key="Theme.Light"
                                        Content="浅色"
                                        Tag="Light" />
                                    <ComboBoxItem
                                        local:Localization.Key="Theme.Dark"
                                        Content="深色"
                                        Tag="Dark" />
                                </ComboBox>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon
                                        Margin="0,28,0,0"
                                        FontSize="18"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Glyph="&#xE774;"
                                        IsHitTestVisible="False"
                                        VerticalAlignment="Top" />
                                    <ComboBox
                                        x:Name="LanguageComboBox"
                                        Grid.Column="1"
                                        local:Localization.Key="Settings.Language"
                                        Header="界面语言"
                                        SelectionChanged="OnLanguageSelectionChanged" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </NavigationView>
</Page>
