                                        local:Localization.Key="Control.SmartAutoHelp"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="按 CPU 温度线性调整全部风扇；达到紧急温度时切回 Dell 自动模式。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <Grid
                                    x:Name="SmartAutoButtonsGrid"
                                    Grid.Column="1"
                                    ColumnSpacing="10"
                                    RowSpacing="8"
                                    VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="StartAutoButton" Click="OnStartAutoPolicyClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE768;" />
                                            <TextBlock local:Localization.Key="Action.StartAuto" Text="启动自动" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        x:Name="StopAutoButton"
                                        Grid.Column="1"
                                        Click="OnStopAutoPolicyClick"
                                        IsEnabled="False">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE71A;" />
                                            <TextBlock local:Localization.Key="Action.Stop" Text="停止" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
