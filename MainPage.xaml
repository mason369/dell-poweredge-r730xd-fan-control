                                                    Grid.Column="1"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    SmallChange="1"
                                                    SpinButtonPlacementMode="Inline"
                                                    Value="{Binding Percent, Mode=TwoWay}" />
