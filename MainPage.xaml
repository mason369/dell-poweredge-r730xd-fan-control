<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DellR730xdFanControlCenter.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DellR730xdFanControlCenter"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnPageLoaded"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
        <DataTemplate x:Key="HardwareTileTemplate">
            <Border
                Width="226"
                MinHeight="126"
                Margin="0,0,10,10"
                Padding="14"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="{Binding IconBackgroundBrush}"
                        CornerRadius="8">
                        <Grid
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Grid Opacity="{Binding FanIconOpacity}">
                                <Ellipse
                                    Width="23"
                                    Height="23"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeThickness="1.6"
                                    Opacity="0.55" />
                                <Grid
                                    x:Name="FanTileRotor"
                                    Width="21"
                                    Height="21"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    DataContextChanged="OnDashboardTileFanIconDataContextChanged"
                                    Loaded="OnDashboardTileFanIconLoaded"
                                    RenderTransformOrigin="0.5,0.5">
                                    <Path
                                        Data="M11.2,2.2 C13.5,1.4 15.9,3.0 15.7,5.5 C15.6,7.6 14.0,9.0 12.5,10.0 C12.0,9.8 11.5,9.8 11.0,10.0 C10.4,8.1 9.5,5.4 11.2,2.2 Z M3.0,13.1 C1.8,10.9 3.1,8.3 5.6,7.9 C7.6,7.6 9.2,8.8 10.6,10.1 C10.3,10.6 10.2,11.1 10.3,11.6 C8.4,12.2 5.8,13.6 3.0,13.1 Z M12.7,21.8 C10.3,22.4 8.0,20.6 8.4,18.1 C8.7,16.1 10.3,14.8 11.9,13.9 C12.4,14.1 12.9,14.1 13.4,13.9 C13.8,15.9 14.5,18.6 12.7,21.8 Z M21.0,10.9 C22.2,13.1 20.9,15.7 18.4,16.1 C16.4,16.4 14.8,15.2 13.4,13.9 C13.7,13.4 13.8,12.9 13.7,12.4 C15.6,11.8 18.2,10.4 21.0,10.9 Z"
                                        Fill="{Binding AccentBrush}" />
                                    <Ellipse
                                        Width="4.4"
                                        Height="4.4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Fill="{Binding AccentBrush}" />
                                </Grid>
                            </Grid>
                            <Grid Opacity="{Binding TemperatureIconOpacity}">
                                <Path
                                    Data="M10,4 A2,2 0 0 1 14,4 L14,12.1 A5,5 0 1 1 10,12.1 Z M11.4,4 L11.4,13.2 L10.8,13.8 A2.6,2.6 0 1 0 13.2,13.8 L12.6,13.2 L12.6,4 Z"
                                    Fill="{Binding AccentBrush}" />
                            </Grid>
                            <Grid
                                x:Name="ElectricalTilePulse"
                                Opacity="{Binding PowerIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M13,2 L4,14 H10 L8,22 L20,9 H13 Z"
                                    Fill="{Binding AccentBrush}" />
                            </Grid>
                            <Grid
                                Opacity="{Binding VoltageIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M5,5 H19 V15 H5 Z M7,7 V13 H17 V7 Z M10,17 H14 V21 H10 Z"
                                    Fill="{Binding AccentBrush}" />
                                <Path
                                    Data="M12.6,8 L9.4,12 H12 L11.1,15 L15,10.5 H12.3 Z"
                                    Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                            </Grid>
                            <Grid
                                Opacity="{Binding CurrentIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M4,13 C6,7 10,7 12,13 C14,19 18,19 20,13"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                                <Path
                                    Data="M17,10 L20,13 L17,16"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                            </Grid>
                            <Grid Opacity="{Binding HealthIconOpacity}">
                                <Ellipse
                                    Width="22"
                                    Height="22"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeThickness="2" />
                                <Path
                                    Data="M7,12 L10.5,15.5 L17,8.5"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                            </Grid>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding Title}"
                            TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock
                                Foreground="{Binding ValueBrush}"
                                FontSize="26"
                                FontWeight="SemiBold"
                                Text="{Binding Value}"
                                TextWrapping="Wrap" />
                            <TextBlock
                                VerticalAlignment="Bottom"
                                Style="{StaticResource MutedTextStyle}"
                                Text="{Binding Unit}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBlock
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Subtitle}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Status}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HardwareStatusRowTemplate">
            <Border
                MinHeight="76"
                Padding="14"
                HorizontalAlignment="Stretch"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{Binding IconBackgroundBrush}"
                        CornerRadius="8">
                        <Grid
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Grid
                                Opacity="{Binding PowerIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M13,2 L4,14 H10 L8,22 L20,9 H13 Z"
                                    Fill="{Binding AccentBrush}" />
                            </Grid>
                            <Grid
                                Opacity="{Binding VoltageIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M5,5 H19 V15 H5 Z M7,7 V13 H17 V7 Z M10,17 H14 V21 H10 Z"
                                    Fill="{Binding AccentBrush}" />
                                <Path
                                    Data="M12.6,8 L9.4,12 H12 L11.1,15 L15,10.5 H12.3 Z"
                                    Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                            </Grid>
                            <Grid
                                Opacity="{Binding CurrentIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M4,13 C6,7 10,7 12,13 C14,19 18,19 20,13"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                                <Path
                                    Data="M17,10 L20,13 L17,16"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                            </Grid>
                            <Grid Opacity="{Binding HealthIconOpacity}">
                                <Ellipse
                                    Width="22"
                                    Height="22"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeThickness="2" />
                                <Path
                                    Data="M7,12 L10.5,15.5 L17,8.5"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                            </Grid>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding Title}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Subtitle}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Status}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="2"
                        MinWidth="160"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="4">
                        <TextBlock
                            Foreground="{Binding ValueBrush}"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{Binding Value}"
                            TextAlignment="Right"
                            TextWrapping="Wrap" />
                        <TextBlock
                            VerticalAlignment="Bottom"
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Unit}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <NavigationView
        x:Name="ShellNavigation"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        PaneDisplayMode="LeftCompact"
        SelectionChanged="OnNavigationSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem
                local:Localization.Key="Nav.Overview"
                Content="总览"
                IsSelected="True"
                Tag="Overview">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                local:Localization.Key="Nav.Control"
                Content="风扇控制"
                Tag="Control">
                <NavigationViewItem.Icon>
                    <PathIcon Data="M12,2 C14.2,2 15.6,4.2 14.7,6.2 L13.2,9.4 C12.4,9.1 11.6,9.1 10.8,9.4 L9.3,6.2 C8.4,4.2 9.8,2 12,2 Z M3.9,7.4 C5.0,5.5 7.8,5.7 9.0,7.6 L10.8,10.4 C10.3,10.9 10,11.4 10,12.1 L6.7,12.2 C4.5,12.3 2.8,9.4 3.9,7.4 Z M20.1,16.6 C19.0,18.5 16.2,18.3 15.0,16.4 L13.2,13.6 C13.7,13.1 14,12.6 14,11.9 L17.3,11.8 C19.5,11.7 21.2,14.6 20.1,16.6 Z M12,10 A2,2 0 1 1 12,14 A2,2 0 0 1 12,10 Z" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                local:Localization.Key="Nav.Sensors"
                Content="传感器"
                Tag="Sensors">
                <NavigationViewItem.Icon>
                    <PathIcon Data="M6,4 H18 V16 H6 Z M8,6 V14 H16 V6 Z M3,7 H5 V9 H3 Z M3,11 H5 V13 H3 Z M19,7 H21 V9 H19 Z M19,11 H21 V13 H19 Z M9,1 H11 V3 H9 Z M13,1 H15 V3 H13 Z M9,17 H11 V20 H9 Z M13,17 H15 V20 H13 Z" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                local:Localization.Key="Nav.Settings"
                Content="设置"
                Tag="Settings">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <InfoBar
                x:Name="StatusInfoBar"
                Margin="24,12,24,0"
                IsClosable="True"
                IsOpen="False"
                Severity="Informational" />

            <ScrollViewer
                x:Name="ContentScrollViewer"
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled">
                <StackPanel
                    Width="{Binding ViewportWidth, ElementName=ContentScrollViewer}"
                    HorizontalAlignment="Left"
                    Padding="24"
                    Spacing="18">
                    <Border
                        MinHeight="202"
                        Padding="24"
                        CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0B1020" Offset="0" />
                                <GradientStop Color="#104E64" Offset="0.42" />
                                <GradientStop Color="#0EA5A4" Offset="0.72" />
                                <GradientStop Color="#2F80ED" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.ColumnSpan="2"
                                Height="1"
                                Margin="0,0,0,4"
                                VerticalAlignment="Bottom"
                                Background="#35FFFFFF" />
                            <Border
                                Grid.ColumnSpan="2"
                                Width="520"
                                Height="176"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Opacity="0.28">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00FFFFFF" Offset="0" />
                                        <GradientStop Color="#60FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    local:Localization.Key="Hero.AppName"
                                    Text="Dell R730xd iDRAC 风扇控制中心" />
                                <TextBlock
                                    Foreground="White"
                                    FontSize="32"
                                    FontWeight="SemiBold"
                                    local:Localization.Key="Hero.Title"
                                    Text="R730XD 智控风扇中心" />
                                <TextBlock
                                    MaxWidth="780"
                                    Foreground="#DDEFFF"
                                    local:Localization.Key="Hero.Subtitle"
                                    Text="监控 BMC 传感器，控制全部或单个风扇，支持 Dell 自动模式与软件恒温策略。" />
                                <Grid
                                    MaxWidth="900"
                                    Margin="0,10,0,0"
                                    ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        Height="124"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LiveTemperature"
                                                Text="实时温度"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLiveTemperatureText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLiveTemperatureItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                MaxLines="3"
                                                Text="--"
                                                TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Grid.Column="1"
                                        Height="124"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LiveFanRpm"
                                                Text="平均转速"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLiveFanRpmText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLiveFanItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                MaxLines="3"
                                                Text="--"
                                                TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Grid.Column="2"
                                        Height="124"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LivePower"
                                                Text="实时功耗"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLivePowerText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLivePowerItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                MaxLines="3"
                                                Text="--"
                                                TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Grid.Column="3"
                                        Height="124"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LiveVoltage"
                                                Text="平均电压"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLiveVoltageText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLiveVoltageItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                MaxLines="3"
                                                Text="--"
                                                TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Grid.Column="4"
                                        Height="124"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LiveCurrent"
                                                Text="总电流"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLiveCurrentText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextTrimming="CharacterEllipsis" />
                                            <TextBlock
                                                x:Name="HeroLiveCurrentItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                MaxLines="3"
                                                Text="--"
                                                TextWrapping="NoWrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                            <Border
                                Grid.Column="1"
                                x:Name="HeroStatusCard"
                                Width="340"
                                MinWidth="320"
                                Padding="18,14"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="#1FFFFFFF"
                                BorderBrush="#38FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        Foreground="#D8F7FF"
                                        local:Localization.Key="Hero.Target"
                                        Text="当前目标" />
                                    <TextBlock
                                        x:Name="CurrentTargetText"
                                        Foreground="White"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Text="192.168.1.73" />
                                    <TextBlock
                                        Foreground="#D8F7FF"
                                        FontSize="12"
                                        local:Localization.Key="Hero.ConnectionStatus"
                                        Text="连接状态" />
                                    <TextBlock
                                        x:Name="ConnectionStateText"
                                        Foreground="#CFFAFE"
                                        Text="未连接"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Foreground="#D8F7FF"
                                        FontSize="12"
                                        local:Localization.Key="Hero.ModeStatus"
                                        Text="控制模式" />
                                    <TextBlock
                                        x:Name="HeroModeStateText"
                                        Foreground="#CFFAFE"
                                        Text="待机"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Foreground="#D8F7FF"
                                        FontSize="12"
                                        local:Localization.Key="Hero.RequestStatus"
                                        Text="请求状态" />
                                    <TextBlock
                                        x:Name="HeroRequestStateText"
                                        Foreground="White"
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Text="等待操作"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="HeroRequestUpdatedText"
                                        Foreground="#CFFAFE"
                                        FontSize="12"
                                        Text="尚无请求记录"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid x:Name="OverviewView">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid Grid.ColumnSpan="3" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        local:Localization.Key="Overview.MaxCpuTemp"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="最高 CPU 温度" />
                                    <TextBlock
                                        x:Name="CpuTemperatureText"
                                        Style="{StaticResource MetricValueStyle}"
                                        Text="-- °C"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        local:Localization.Key="Overview.FromSdrTemp"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="来自 SDR 温度传感器"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        local:Localization.Key="Overview.FanStatus"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="风扇状态" />
                                    <TextBlock
                                        x:Name="FanSummaryText"
                                        Style="{StaticResource MetricValueStyle}"
                                        Text="6 个风扇"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="FanRpmSummaryText"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="等待刷新"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        local:Localization.Key="Overview.LivePower"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="实时功耗" />
                                    <TextBlock
                                        x:Name="PowerSummaryText"
                                        Style="{StaticResource MetricValueStyle}"
                                        Text="-- 瓦"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="PowerSummaryDetailText"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="等待刷新"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        local:Localization.Key="Overview.AverageVoltage"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="平均电压" />
                                    <TextBlock
                                        x:Name="VoltageSummaryText"
                                        Style="{StaticResource MetricValueStyle}"
                                        Text="-- 伏"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="VoltageSummaryDetailText"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="等待刷新"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        local:Localization.Key="Overview.TotalCurrent"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="总电流" />
                                    <TextBlock
                                        x:Name="CurrentSummaryText"
                                        Style="{StaticResource MetricValueStyle}"
                                        Text="-- 安"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="CurrentSummaryDetailText"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="等待刷新"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="5" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        local:Localization.Key="Overview.Mode"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="控制模式" />
                                    <TextBlock
                                        x:Name="ModeSummaryText"
                                        Style="{StaticResource MetricValueStyle}"
                                        Text="待机"
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        x:Name="AutoPolicySummaryText"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="软件自动策略未运行"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            local:Localization.Key="Overview.VisualizationBoard"
                                            Style="{StaticResource SectionTitleStyle}"
                                            Text="交互式数据可视化" />
                                        <TextBlock
                                            local:Localization.Key="Overview.VisualizationHelp"
                                            Style="{StaticResource MutedTextStyle}"
                                            Text="总览趋势、单项硬件、按硬件类型和健康状态的交互图表。" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="VisualizationStateText"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="等待图表加载" />
                                </Grid>
                                <WebView2
                                    x:Name="VisualizationWebView"
                                    MinHeight="760"
                                    Loaded="OnVisualizationWebViewLoaded"
                                    NavigationCompleted="OnVisualizationNavigationCompleted" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            local:Localization.Key="Overview.TempBoard"
                                            Style="{StaticResource SectionTitleStyle}"
                                            Text="温度大看板" />
                                        <TextBlock
                                            local:Localization.Key="Overview.TempBoardHelp"
                                            Style="{StaticResource MutedTextStyle}"
                                            Text="逐项显示 BMC SDR 中的每一个温度传感器。" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="LastPollText"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="等待轮询" />
                                </Grid>
                                <GridView
                                    MaxHeight="300"
                                    ItemTemplate="{StaticResource HardwareTileTemplate}"
                                    IsItemClickEnabled="False"
                                    ItemsSource="{x:Bind TemperatureTiles, Mode=OneWay}"
                                    SelectionMode="None">
                                    <GridView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </GridView.ItemsPanel>
                                </GridView>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    local:Localization.Key="Overview.FanBoard"
                                    Style="{StaticResource SectionTitleStyle}"
                                    Text="风扇 RPM 看板" />
                                <GridView
                                    MaxHeight="260"
                                    ItemTemplate="{StaticResource HardwareTileTemplate}"
                                    IsItemClickEnabled="False"
                                    ItemsSource="{x:Bind FanTiles, Mode=OneWay}"
                                    SelectionMode="None">
                                    <GridView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </GridView.ItemsPanel>
                                </GridView>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    local:Localization.Key="Overview.PowerHealth"
                                    Style="{StaticResource SectionTitleStyle}"
                                    Text="功耗与状态" />
                                <ListView
                                    MaxHeight="340"
                                    ItemTemplate="{StaticResource HardwareStatusRowTemplate}"
                                    ItemsSource="{x:Bind PowerTiles, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0,0,0,8" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="5" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="14">
                                    <TextBlock
                                        local:Localization.Key="Overview.QuickActions"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="快速操作" />
                                    <CommandBar DefaultLabelPosition="Right" IsOpen="False">
                                        <AppBarButton
                                            Click="OnTestConnectionClick"
                                            Icon="Contact"
                                            local:Localization.Key="Action.Connect"
                                            Label="连接" />
                                        <AppBarButton
                                            Click="OnRefreshSensorsClick"
                                            Icon="Refresh"
                                            local:Localization.Key="Action.RefreshSensors"
                                            Label="刷新传感器" />
                                        <AppBarButton
                                            Click="OnRestoreDefaultClick"
                                            Icon="Sync"
                                            local:Localization.Key="Action.RestoreDellFactoryFanSpeed"
                                            Label="还原戴尔出厂设置转速" />
                                        <AppBarButton
                                            Click="OnVisitIdracClick"
                                            Icon="World"
                                            local:Localization.Key="Action.OpenIdrac"
                                            Label="打开 iDRAC" />
                                    </CommandBar>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock
                                        local:Localization.Key="Overview.AllFans"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="全部风扇" />
                                    <Slider
                                        x:Name="AllFanSlider"
                                        Maximum="100"
                                        Minimum="0"
                                        StepFrequency="1"
                                        ValueChanged="OnAllFanSliderChanged" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <NumberBox
                                            x:Name="AllFanPercentBox"
                                            Grid.Column="1"
                                            Maximum="100"
                                            Minimum="0"
                                            SmallChange="1"
                                            SpinButtonPlacementMode="Inline"
                                            ValueChanged="OnAllFanNumberChanged" />
                                        <Button Grid.Column="2" Click="OnSetAllFansClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                                <TextBlock local:Localization.Key="Action.Apply" Text="应用" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="6" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            local:Localization.Key="Overview.RecentLog"
                                            Style="{StaticResource SectionTitleStyle}"
                                            Text="最新日志" />
                                        <Button Grid.Column="1" Click="OnOpenLogFolderClick">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon FontSize="14" Glyph="&#xE8B7;" />
                                                <TextBlock local:Localization.Key="Action.OpenLogFolder" Text="打开日志文件夹" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                    <ListView
                                        MaxHeight="220"
                                        ItemsSource="{x:Bind Logs, Mode=OneWay}"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64" />
                                                        <ColumnDefinition Width="78" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DisplayTime}" />
                                                    <Border
                                                        Grid.Column="1"
                                                        MinWidth="54"
                                                        Padding="8,2"
                                                        HorizontalAlignment="Left"
                                                        Background="{Binding LevelBackgroundBrush}"
                                                        BorderBrush="{Binding LevelBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                        <TextBlock
                                                            Foreground="{Binding LevelForegroundBrush}"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding Level}"
                                                            TextAlignment="Center"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </Border>
                                                    <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="ControlView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="16">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            local:Localization.Key="Control.Presets"
                                            Style="{StaticResource SectionTitleStyle}"
                                            Text="预设模式" />
                                        <TextBlock
                                            x:Name="ControlCurrentModeText"
                                            Style="{StaticResource MutedTextStyle}"
                                            Text="当前模式：待机" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        local:Localization.Key="Control.PresetRules"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="预设规则" />
                                </Grid>

                                <GridView
                                    Padding="0"
                                    IsItemClickEnabled="False"
                                    ItemsSource="{x:Bind Presets, Mode=OneWay}"
                                    SelectionMode="None">
                                    <GridView.ItemContainerStyle>
                                        <Style TargetType="GridViewItem">
                                            <Setter Property="Margin" Value="0,0,12,12" />
                                            <Setter Property="MinWidth" Value="300" />
                                            <Setter Property="MaxWidth" Value="340" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        </Style>
                                    </GridView.ItemContainerStyle>
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Width="320"
                                                MinHeight="360"
                                                Padding="16"
                                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <Grid RowSpacing="12">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="*" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <Grid ColumnSpacing="12">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border
                                                            Width="42"
                                                            Height="42"
                                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                            CornerRadius="8">
                                                            <FontIcon
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                FontSize="18"
                                                                Foreground="White"
                                                                Glyph="{Binding IconGlyph}" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" Spacing="4">
                                                            <TextBox
                                                                MinWidth="150"
                                                                Padding="8,4"
                                                                FontSize="16"
                                                                FontWeight="SemiBold"
                                                                Header="预设名称"
                                                                local:Localization.Key="Preset.Name"
                                                                Text="{Binding EditableName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                            <TextBlock
                                                                Style="{StaticResource MutedTextStyle}"
                                                                Text="{Binding ModeBadge}"
                                                                TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <Border
                                                            Grid.Column="2"
                                                            Opacity="{Binding CurrentMarkerOpacity}"
                                                            Padding="8,4"
                                                            VerticalAlignment="Top"
                                                            Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                                            CornerRadius="8">
                                                            <TextBlock
                                                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                                FontSize="12"
                                                                FontWeight="SemiBold"
                                                                Text="{Binding CurrentMarker}" />
                                                        </Border>
                                                    </Grid>

                                                    <Grid Grid.Row="1" RowSpacing="6">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock
                                                            FontSize="34"
                                                            FontWeight="SemiBold"
                                                            Text="{Binding PrimaryMetric}" />
                                                        <TextBlock
                                                            Grid.Row="1"
                                                            Style="{StaticResource MutedTextStyle}"
                                                            Text="{Binding Subtitle}" />
                                                        <TextBox
                                                            Grid.Row="2"
                                                            AcceptsReturn="True"
                                                            Header="预设说明"
                                                            local:Localization.Key="Preset.Description"
                                                            MaxLength="180"
                                                            MaxHeight="76"
                                                            MinHeight="64"
                                                            Text="{Binding EditableDetail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            TextWrapping="Wrap" />
                                                    </Grid>

                                                    <NumberBox
                                                        Grid.Row="2"
                                                        Header="%"
                                                        IsEnabled="{Binding CanEditPercent}"
                                                        Maximum="100"
                                                        Minimum="0"
                                                        SmallChange="1"
                                                        SpinButtonPlacementMode="Compact"
                                                        Value="{Binding Percent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                    <StackPanel Grid.Row="3" Spacing="6">
                                                        <CheckBox
                                                            Content="平滑曲线"
                                                            IsChecked="{Binding SmoothCurve, Mode=TwoWay}"
                                                            IsEnabled="{Binding CanEditCurve}"
                                                            local:Localization.Key="Preset.SmoothCurve" />
                                                        <TextBlock
                                                            Style="{StaticResource MutedTextStyle}"
                                                            Text="{Binding CurvePreviewHeader}" />
                                                        <TextBlock
                                                            FontFamily="Consolas"
                                                            Style="{StaticResource MutedTextStyle}"
                                                            Text="{Binding CurveChartText}"
                                                            TextWrapping="Wrap" />
                                                        <Button
                                                            Click="OnEditCurvePresetClick"
                                                            IsEnabled="{Binding CanEditCurve}"
                                                            Tag="{Binding Id}">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                                                <TextBlock local:Localization.Key="Preset.EditCurvePoints" Text="编辑点位" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>

                                                    <Grid Grid.Row="4" ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <Button
                                                            HorizontalAlignment="Stretch"
                                                            Click="OnApplyPresetClick"
                                                            Style="{StaticResource AccentButtonStyle}"
                                                            Tag="{Binding Id}">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon FontSize="14" Glyph="&#xE768;" />
                                                                <TextBlock Text="{Binding ApplyButtonLabel}" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button
                                                            Grid.Column="1"
                                                            Click="OnSavePresetClick"
                                                            IsEnabled="{Binding CanSave}"
                                                            Tag="{Binding Id}"
                                                            ToolTipService.ToolTip="{Binding SaveButtonLabel}">
                                                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                                        </Button>
                                                        <Button
                                                            Grid.Column="2"
                                                            Click="OnDeletePresetClick"
                                                            IsEnabled="{Binding CanDelete}"
                                                            Tag="{Binding Id}"
                                                            ToolTipService.ToolTip="{Binding DeleteButtonLabel}">
                                                            <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                        </Button>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="NewPresetNameBox"
                                        local:Localization.Key="Preset.Name"
                                        Header="预设名称"
                                        PlaceholderText="例如：夜间静音" />
                                    <NumberBox
                                        x:Name="NewPresetPercentBox"
                                        Grid.Column="1"
                                        local:Localization.Key="Preset.Percent"
                                        Header="风扇百分比"
                                        Maximum="100"
                                        Minimum="0"
                                        SmallChange="1"
                                        SpinButtonPlacementMode="Inline"
                                        Value="10" />
                                    <Button
                                        Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Click="OnAddPresetClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                                            <TextBlock local:Localization.Key="Control.AddPreset" Text="添加手动预设" />
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <StackPanel Spacing="10">
                                    <TextBlock
                                        local:Localization.Key="Control.CurvePresetPoints"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="温度-风扇曲线点" />
                                    <TextBlock
                                        local:Localization.Key="Control.CurvePresetHelp"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="在曲线图上点击添加点位，或用右侧数值控件微调温度和风扇百分比；开启平滑后会按点位做平滑曲线过渡。" />
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.1*" />
                                            <ColumnDefinition Width="1.6*" />
                                            <ColumnDefinition Width="1.2*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="10">
                                            <TextBox
                                                x:Name="NewCurvePresetNameBox"
                                                local:Localization.Key="Control.CurvePresetName"
                                                Header="曲线预设名称"
                                                PlaceholderText="例如：CPU 温控曲线" />
                                            <ToggleSwitch
                                                x:Name="NewCurveSmoothSwitch"
                                                Header="平滑曲线"
                                                local:Localization.Key="Preset.SmoothCurve"
                                                Toggled="OnNewCurveSmoothToggled" />
                                            <TextBlock
                                                x:Name="NewCurveEditorModeText"
                                                local:Localization.Key="Control.NewCurveEditor"
                                                Style="{StaticResource MutedTextStyle}"
                                                Text="新建曲线" />
                                            <Button Click="OnResetNewCurveEditorClick">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon FontSize="14" Glyph="&#xE777;" />
                                                    <TextBlock local:Localization.Key="Action.ResetEditor" Text="重置编辑器" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                        <Border
                                            Grid.Column="1"
                                            MinHeight="220"
                                            Padding="12"
                                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <Grid>
                                                <Canvas
                                                    x:Name="NewCurveCanvas"
                                                    MinHeight="196"
                                                    Background="Transparent"
                                                    PointerPressed="OnNewCurveCanvasPointerPressed"
                                                    SizeChanged="OnNewCurveCanvasSizeChanged" />
                                                <TextBlock
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Bottom"
                                                    Style="{StaticResource MutedTextStyle}"
                                                    Text="30°C" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Style="{StaticResource MutedTextStyle}"
                                                    Text="95°C" />
                                                <TextBlock
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Top"
                                                    Style="{StaticResource MutedTextStyle}"
                                                    Text="100%" />
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="2" Spacing="8">
                                            <ListView
                                                MaxHeight="180"
                                                ItemsSource="{x:Bind NewCurvePoints, Mode=OneWay}"
                                                SelectionMode="None">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid ColumnSpacing="8" Padding="0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <NumberBox
                                                                Header="温度 °C"
                                                                local:Localization.Key="Field.CurveTemperature"
                                                                Maximum="125"
                                                                Minimum="-40"
                                                                SmallChange="1"
                                                                SpinButtonPlacementMode="Compact"
                                                                Tag="Temperature"
                                                                ValueChanged="OnNewCurvePointValueChanged"
                                                                Value="{Binding TemperatureCelsius, Mode=TwoWay}" />
                                                            <NumberBox
                                                                Grid.Column="1"
                                                                Header="风扇 %"
                                                                local:Localization.Key="Field.CurveFanPercent"
                                                                Maximum="100"
                                                                Minimum="0"
                                                                SmallChange="1"
                                                                SpinButtonPlacementMode="Compact"
                                                                Tag="Percent"
                                                                ValueChanged="OnNewCurvePointValueChanged"
                                                                Value="{Binding FanPercent, Mode=TwoWay}" />
                                                            <Button
                                                                Grid.Column="2"
                                                                Click="OnDeleteNewCurvePointClick"
                                                                DataContext="{Binding}">
                                                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                            </Button>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <NumberBox
                                                    x:Name="NewCurveTemperatureBox"
                                                    Header="温度 °C"
                                                    local:Localization.Key="Field.CurveTemperature"
                                                    Maximum="125"
                                                    Minimum="-40"
                                                    SmallChange="1"
                                                    SpinButtonPlacementMode="Compact"
                                                    Value="68" />
                                                <NumberBox
                                                    x:Name="NewCurvePercentBox"
                                                    Grid.Column="1"
                                                    Header="风扇 %"
                                                    local:Localization.Key="Field.CurveFanPercent"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    SmallChange="1"
                                                    SpinButtonPlacementMode="Compact"
                                                    Value="28" />
                                                <Button
                                                    Grid.Column="2"
                                                    VerticalAlignment="Bottom"
                                                    Click="OnAddNewCurvePointClick">
                                                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                                                </Button>
                                            </Grid>
                                            <TextBlock
                                                x:Name="NewCurvePreviewText"
                                                FontFamily="Consolas"
                                                Style="{StaticResource MutedTextStyle}"
                                                TextWrapping="Wrap" />
                                            <Button Click="OnAddCurvePresetClick">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                                                    <TextBlock x:Name="AddCurvePresetButtonText" local:Localization.Key="Control.AddCurvePreset" Text="添加曲线预设" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="10">
                                    <TextBlock
                                        local:Localization.Key="Control.SmartAutoPolicy"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="软件恒温策略" />
                                    <TextBlock
                                        local:Localization.Key="Control.SmartAutoHelp"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="按 CPU 温度线性调整全部风扇；达到紧急温度时切回 Dell 自动模式。"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <Grid Grid.Column="1" ColumnSpacing="10" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="StartAutoButton" Click="OnStartAutoPolicyClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE768;" />
                                            <TextBlock local:Localization.Key="Action.StartAuto" Text="启动自动" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        x:Name="StopAutoButton"
                                        Grid.Column="1"
                                        Click="OnStopAutoPolicyClick"
                                        IsEnabled="False">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE71A;" />
                                            <TextBlock local:Localization.Key="Action.Stop" Text="停止" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="2" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock
                                    local:Localization.Key="Control.IndividualFans"
                                    Style="{StaticResource SectionTitleStyle}"
                                    Text="单风扇控制" />
                                <InfoBar
                                    x:Name="IndividualFanInfoBar"
                                    IsOpen="True"
                                    Severity="Warning"
                                    Message="单风扇控制当前未启用。0x00 是目标编号，不是 0% 转速；需要控制单个风扇时，请先在设置中开启并保存。" />
                                <TextBlock
                                    local:Localization.Key="Control.IndividualHelp"
                                    Style="{StaticResource MutedTextStyle}"
                                    Text="启用后会发送 Dell OEM raw 命令：Fan 1-6 使用目标编号 0x00-0x05。目标编号不是转速；若行为不符合预期，请立即恢复 Dell 自动模式。" />
                                <ListView ItemsSource="{x:Bind FanChannels, Mode=OneWay}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,8" ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding ChineseName}" />
                                                </StackPanel>
                                                <Slider
                                                    Grid.Column="1"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    StepFrequency="1"
                                                    Value="{Binding Percent, Mode=TwoWay}" />
                                                <NumberBox
                                                    Grid.Column="2"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    SmallChange="1"
                                                    SpinButtonPlacementMode="Inline"
                                                    Value="{Binding Percent, Mode=TwoWay}" />
                                                <Button
                                                    Grid.Column="3"
                                                    Click="OnSetSingleFanClick"
                                                    Tag="{Binding Index}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                                        <TextBlock Text="{Binding SetButtonLabel}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="6">
                                    <TextBlock local:Localization.Key="Control.TargetTemp" Text="目标温度" />
                                    <NumberBox x:Name="TargetTempBox" Maximum="95" Minimum="30" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock local:Localization.Key="Control.HighTemp" Text="高温" />
                                    <NumberBox x:Name="HighTempBox" Maximum="100" Minimum="40" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock local:Localization.Key="Control.EmergencyAuto" Text="紧急自动" />
                                    <NumberBox x:Name="EmergencyTempBox" Maximum="105" Minimum="45" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="6">
                                    <TextBlock local:Localization.Key="Control.PollSeconds" Text="轮询秒数" />
                                    <NumberBox x:Name="SensorRefreshSecondsBox" Maximum="300" Minimum="15" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="SensorsView" Visibility="Collapsed">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        local:Localization.Key="Sensors.Title"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="BMC 传感器" />
                                    <Button Grid.Column="1" Click="OnRefreshSensorsClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                            <TextBlock local:Localization.Key="Action.Refresh" Text="刷新" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <ListView
                                    MaxHeight="640"
                                    ItemsSource="{x:Bind LocalizedSensors, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.Header>
                                        <Grid Padding="12,6" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                local:Localization.Key="Sensors.Key"
                                                FontWeight="SemiBold"
                                                Text="传感器" />
                                            <TextBlock
                                                Grid.Column="1"
                                                local:Localization.Key="Sensors.Id"
                                                FontWeight="SemiBold"
                                                Text="ID" />
                                            <TextBlock
                                                Grid.Column="2"
                                                local:Localization.Key="Sensors.Entity"
                                                FontWeight="SemiBold"
                                                Text="实体" />
                                            <TextBlock
                                                Grid.Column="3"
                                                local:Localization.Key="Sensors.Value"
                                                FontWeight="SemiBold"
                                                Text="读数" />
                                            <TextBlock
                                                Grid.Column="4"
                                                local:Localization.Key="Sensors.Unit"
                                                FontWeight="SemiBold"
                                                Text="单位" />
                                            <TextBlock
                                                Grid.Column="5"
                                                local:Localization.Key="Sensors.Status"
                                                FontWeight="SemiBold"
                                                Text="状态" />
                                        </Grid>
                                    </ListView.Header>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="12,7" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Key}" />
                                                <TextBlock Grid.Column="1" Text="{Binding SensorId}" />
                                                <TextBlock Grid.Column="2" Text="{Binding Entity}" />
                                                <TextBlock Grid.Column="3" Text="{Binding Value}" />
                                                <TextBlock Grid.Column="4" Text="{Binding Unit}" />
                                                <TextBlock Grid.Column="5" Text="{Binding Status}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="SettingsView" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,9,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    local:Localization.Key="Settings.Connection"
                                    Style="{StaticResource SectionTitleStyle}"
                                    Text="iDRAC 连接" />
                                <TextBox
                                    x:Name="HostBox"
                                    local:Localization.Key="Settings.Host"
                                    Header="BMC/iDRAC IP" />
                                <TextBox
                                    x:Name="UserNameBox"
                                    local:Localization.Key="Settings.UserName"
                                    Header="用户名" />
                                <PasswordBox
                                    x:Name="PasswordBox"
                                    local:Localization.Key="Settings.Password"
                                    Header="密码"
                                    PasswordRevealMode="Peek" />
                                <ToggleSwitch
                                    x:Name="RememberPasswordSwitch"
                                    local:Localization.Key="Settings.RememberPassword"
                                    Header="使用 DPAPI 保存密码" />
                                <TextBox
                                    x:Name="IpmiToolPathBox"
                                    local:Localization.Key="Settings.BundledIpmiPath"
                                    Header="内置 ipmitool 路径"
                                    IsReadOnly="True" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Click="OnSaveSettingsClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                            <TextBlock local:Localization.Key="Action.Save" Text="保存设置" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Click="OnTestConnectionClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE8FB;" />
                                            <TextBlock local:Localization.Key="Action.Connect" Text="连接" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    local:Localization.Key="Settings.Application"
                                    Style="{StaticResource SectionTitleStyle}"
                                    Text="应用设置" />
                                <ToggleSwitch
                                    x:Name="MinimizeToTraySwitch"
                                    local:Localization.Key="Settings.MinimizeToTray"
                                    Header="点击关闭时最小化到托盘" />
                                <ToggleSwitch
                                    x:Name="IndividualFanSwitch"
                                    local:Localization.Key="Settings.EnableIndividualFanTargets"
                                    Header="启用单风扇目标编号控制"
                                    Toggled="OnIndividualFanSwitchToggled" />
                                <NumberBox
                                    x:Name="FanCountBox"
                                    local:Localization.Key="Settings.FanCount"
                                    Header="风扇数量"
                                    Maximum="6"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="CommandTimeoutBox"
                                    local:Localization.Key="Settings.CommandTimeout"
                                    Header="命令超时秒数"
                                    Maximum="180"
                                    Minimum="5"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="AutoMinFanBox"
                                    local:Localization.Key="Settings.AutoMinFan"
                                    Header="自动策略最小风扇百分比"
                                    Maximum="100"
                                    Minimum="0"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="AutoMaxFanBox"
                                    local:Localization.Key="Settings.AutoMaxFan"
                                    Header="自动策略最大风扇百分比"
                                    Maximum="100"
                                    Minimum="0"
                                    SpinButtonPlacementMode="Inline" />
                                <ComboBox
                                    x:Name="ThemeComboBox"
                                    local:Localization.Key="Settings.Theme"
                                    Header="主题">
                                    <ComboBoxItem
                                        local:Localization.Key="Theme.System"
                                        Content="跟随系统"
                                        Tag="Default" />
                                    <ComboBoxItem
                                        local:Localization.Key="Theme.Light"
                                        Content="浅色"
                                        Tag="Light" />
                                    <ComboBoxItem
                                        local:Localization.Key="Theme.Dark"
                                        Content="深色"
                                        Tag="Dark" />
                                </ComboBox>
                                <ComboBox
                                    x:Name="LanguageComboBox"
                                    local:Localization.Key="Settings.Language"
                                    Header="界面语言"
                                    SelectionChanged="OnLanguageSelectionChanged">
                                    <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                                    <ComboBoxItem Content="English" Tag="en-US" />
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </NavigationView>
</Page>
