                                                            Click="OnEditCurvePresetClick"
                                                            IsEnabled="{Binding CanEditCurve}"
                                                            Tag="{Binding Id}">
                                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                                <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                                                <TextBlock local:Localization.Key="Preset.EditCurvePoints" Text="编辑点位" />
                                                            </StackPanel>
                                                        </Button>
                                                    </StackPanel>

                                                    <Grid Grid.Row="4" ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
