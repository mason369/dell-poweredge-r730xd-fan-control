<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DellR730xdFanControlCenter.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DellR730xdFanControlCenter"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnPageLoaded"
    SizeChanged="OnPageSizeChanged"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
        <DataTemplate x:Key="HardwareTileTemplate">
            <Border
                Width="250"
                MinHeight="138"
                Padding="14"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="{Binding IconBackgroundBrush}"
                        CornerRadius="8">
                        <Grid
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Grid Opacity="{Binding FanIconOpacity}">
                                <Ellipse
                                    Width="23"
                                    Height="23"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeThickness="1.6"
                                    Opacity="0.55" />
                                <Grid
                                    x:Name="FanTileRotor"
                                    Width="24"
                                    Height="24"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    DataContextChanged="OnDashboardTileFanIconDataContextChanged"
                                    Loaded="OnDashboardTileFanIconLoaded"
                                    RenderTransformOrigin="0.5,0.5"
                                    Unloaded="OnDashboardTileFanIconUnloaded">
                                    <Path
                                        Data="M12,3 C13.8,3 15,4.2 15,6 C15,8.1 13.8,9.7 12.5,10.7 C12.2,10.5 11.8,10.5 11.5,10.7 C10.2,9.7 9,8.1 9,6 C9,4.2 10.2,3 12,3 Z M21,12 C21,13.8 19.8,15 18,15 C15.9,15 14.3,13.8 13.3,12.5 C13.5,12.2 13.5,11.8 13.3,11.5 C14.3,10.2 15.9,9 18,9 C19.8,9 21,10.2 21,12 Z M12,21 C10.2,21 9,19.8 9,18 C9,15.9 10.2,14.3 11.5,13.3 C11.8,13.5 12.2,13.5 12.5,13.3 C13.8,14.3 15,15.9 15,18 C15,19.8 13.8,21 12,21 Z M3,12 C3,10.2 4.2,9 6,9 C8.1,9 9.7,10.2 10.7,11.5 C10.5,11.8 10.5,12.2 10.7,12.5 C9.7,13.8 8.1,15 6,15 C4.2,15 3,13.8 3,12 Z M12,9.7 A2.3,2.3 0 1 1 12,14.3 A2.3,2.3 0 0 1 12,9.7 Z"
                                        Fill="{Binding AccentBrush}" />
                                </Grid>
                            </Grid>
                            <Grid Opacity="{Binding TemperatureIconOpacity}">
                                <Path
                                    Data="M10,4 A2,2 0 0 1 14,4 L14,12.1 A5,5 0 1 1 10,12.1 Z M11.4,4 L11.4,13.2 L10.8,13.8 A2.6,2.6 0 1 0 13.2,13.8 L12.6,13.2 L12.6,4 Z"
                                    Fill="{Binding AccentBrush}" />
                            </Grid>
                            <Grid
                                x:Name="ElectricalTilePulse"
                                Opacity="{Binding PowerIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M13,2 L4,14 H10 L8,22 L20,9 H13 Z"
                                    Fill="{Binding AccentBrush}" />
                            </Grid>
                            <Grid
                                x:Name="VoltageTilePulse"
                                Opacity="{Binding VoltageIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Ellipse
                                    Width="21"
                                    Height="21"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeThickness="1.8"
                                    Opacity="0.6" />
                                <Path
                                    Data="M7,15.8 C8.1,12.4 9.9,10.6 12,10.6 C14.1,10.6 15.9,12.4 17,15.8"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="1.8" />
                                <Path
                                    Data="M12,14.8 L15.8,9.2"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.2" />
                                <Path
                                    Data="M8.5,17.8 H15.5"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="1.8" />
                            </Grid>
                            <Grid
                                x:Name="CurrentTilePulse"
                                Opacity="{Binding CurrentIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Ellipse
                                    Width="21"
                                    Height="21"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeThickness="1.8"
                                    Opacity="0.6" />
                                <Path
                                    Data="M6,12 C7.4,8.8 9.7,8.8 11.1,12 C12.5,15.2 14.8,15.2 16.2,12"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2" />
                                <Path
                                    Data="M15,9.4 L18,12 L15,14.6"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2" />
                            </Grid>
                            <Grid Opacity="{Binding HealthIconOpacity}">
                                <Ellipse
                                    Width="22"
                                    Height="22"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeThickness="2" />
                                <Path
                                    Data="M7,12 L10.5,15.5 L17,8.5"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                            </Grid>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock
                            FontWeight="SemiBold"
                            MaxLines="2"
                            Text="{Binding Title}"
                            TextWrapping="Wrap" />
                        <Grid ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Foreground="{Binding ValueBrush}"
                                FontSize="{Binding ValueFontSize}"
                                FontWeight="SemiBold"
                                MaxLines="{Binding ValueMaxLines}"
                                Text="{Binding Value}"
                                TextWrapping="WrapWholeWords" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource MutedTextStyle}"
                                Text="{Binding Unit}"
                                TextWrapping="Wrap" />
                        </Grid>
                        <TextBlock
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Subtitle}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Status}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate x:Key="HardwareStatusRowTemplate">
            <Border
                MinHeight="76"
                Padding="14"
                HorizontalAlignment="Stretch"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="44" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Width="40"
                        Height="40"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Background="{Binding IconBackgroundBrush}"
                        CornerRadius="8">
                        <Grid
                            Width="24"
                            Height="24"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                            <Grid
                                Opacity="{Binding PowerIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M13,2 L4,14 H10 L8,22 L20,9 H13 Z"
                                    Fill="{Binding AccentBrush}" />
                            </Grid>
                            <Grid
                                Opacity="{Binding VoltageIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M5,5 H19 V15 H5 Z M7,7 V13 H17 V7 Z M10,17 H14 V21 H10 Z"
                                    Fill="{Binding AccentBrush}" />
                                <Path
                                    Data="M12.6,8 L9.4,12 H12 L11.1,15 L15,10.5 H12.3 Z"
                                    Fill="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                            </Grid>
                            <Grid
                                Opacity="{Binding CurrentIconOpacity}"
                                DataContextChanged="OnDashboardTileElectricalIconDataContextChanged"
                                Loaded="OnDashboardTileElectricalIconLoaded"
                                RenderTransformOrigin="0.5,0.5">
                                <Path
                                    Data="M4,13 C6,7 10,7 12,13 C14,19 18,19 20,13"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                                <Path
                                    Data="M17,10 L20,13 L17,16"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                            </Grid>
                            <Grid Opacity="{Binding HealthIconOpacity}">
                                <Ellipse
                                    Width="22"
                                    Height="22"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeThickness="2" />
                                <Path
                                    Data="M7,12 L10.5,15.5 L17,8.5"
                                    Stroke="{Binding AccentBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="2.4" />
                            </Grid>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{Binding Title}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Subtitle}"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Status}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="2"
                        MinWidth="160"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="4">
                        <TextBlock
                            Foreground="{Binding ValueBrush}"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="{Binding Value}"
                            TextAlignment="Right"
                            TextWrapping="Wrap" />
                        <TextBlock
                            VerticalAlignment="Bottom"
                            Style="{StaticResource MutedTextStyle}"
                            Text="{Binding Unit}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <NavigationView
        x:Name="ShellNavigation"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        PaneDisplayMode="LeftCompact"
        SelectionChanged="OnNavigationSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem
                local:Localization.Key="Nav.Overview"
                Content="总览"
                IsSelected="True"
                Tag="Overview">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                local:Localization.Key="Nav.Control"
                Content="风扇控制"
                Tag="Control">
                <NavigationViewItem.Icon>
                    <PathIcon Data="M12,9.7 A2.3,2.3 0 1 1 12,14.3 A2.3,2.3 0 0 1 12,9.7 Z M13.55,10.45 C14.75,8.05 16.9,5.65 19.15,4.85 C20.05,5.75 20.15,7.25 19.4,8.4 C18.15,10.3 15.7,10.95 13.55,10.45 Z M13.55,13.55 C15.95,14.75 18.35,16.9 19.15,19.15 C18.25,20.05 16.75,20.15 15.6,19.4 C13.7,18.15 13.05,15.7 13.55,13.55 Z M10.45,13.55 C9.25,15.95 7.1,18.35 4.85,19.15 C3.95,18.25 3.85,16.75 4.6,15.6 C5.85,13.7 8.3,13.05 10.45,13.55 Z M10.45,10.45 C8.05,9.25 5.65,7.1 4.85,4.85 C5.75,3.95 7.25,3.85 8.4,4.6 C10.3,5.85 10.95,8.3 10.45,10.45 Z" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                local:Localization.Key="Nav.Sensors"
                Content="传感器"
                Tag="Sensors">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE950;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                local:Localization.Key="Nav.Settings"
                Content="设置"
                Tag="Settings">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <InfoBar
                x:Name="StatusInfoBar"
                Margin="24,12,24,0"
                IsClosable="True"
                IsIconVisible="False"
                IsOpen="False"
                Severity="Informational" />

            <ScrollViewer
                x:Name="ContentScrollViewer"
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled">
                <StackPanel
                    x:Name="ContentPanel"
                    Width="{Binding ViewportWidth, ElementName=ContentScrollViewer}"
                    HorizontalAlignment="Left"
                    Padding="24"
                    Spacing="18">
                    <Border
                        x:Name="HeroBannerCard"
                        MinHeight="202"
                        Padding="24"
                        CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0B1020" Offset="0" />
                                <GradientStop Color="#104E64" Offset="0.42" />
                                <GradientStop Color="#0EA5A4" Offset="0.72" />
                                <GradientStop Color="#2F80ED" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid
                            x:Name="HeroBannerLayout"
                            RowSpacing="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border
                                x:Name="HeroBannerGlow"
                                Grid.RowSpan="2"
                                Width="520"
                                Height="176"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Opacity="0.28">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00FFFFFF" Offset="0" />
                                        <GradientStop Color="#60FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <Grid x:Name="HeroBannerContent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    local:Localization.Key="Hero.AppName"
                                    Text="Dell R730xd iDRAC 风扇控制中心" />
                                <TextBlock
                                    Foreground="White"
                                    FontSize="32"
                                    FontWeight="SemiBold"
                                    local:Localization.Key="Hero.Title"
                                    Text="R730XD 智控风扇中心" />
                                <TextBlock
                                    MaxWidth="780"
                                    Foreground="#DDEFFF"
                                    local:Localization.Key="Hero.Subtitle"
                                    Text="监控 BMC 传感器，控制全部或单个风扇，支持 Dell 自动模式与软件恒温策略。" />
                                <Border
                                    x:Name="HeroThermalModeBadge"
                                    MaxWidth="780"
                                    Margin="0,4,0,0"
                                    Padding="10,7"
                                    HorizontalAlignment="Left"
                                    Background="#22FFFFFF"
                                    BorderBrush="#45FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon
                                            Foreground="#CFFAFE"
                                            FontSize="14"
                                            Glyph="&#xE9D2;" />
                                        <TextBlock
                                            x:Name="HeroThermalModeLabelText"
                                            Grid.Column="1"
                                            Foreground="#D8F7FF"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            TextWrapping="Wrap" />
                                        <TextBlock
                                            x:Name="HeroThermalModeValueText"
                                            Grid.Column="2"
                                            Foreground="White"
                                            FontSize="13"
                                            FontWeight="SemiBold"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                                <Grid
                                    x:Name="HeroRealtimeMetricsPanel"
                                    MaxWidth="900"
                                    Margin="0,10,0,0"
                                    ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border
                                        MinHeight="170"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LiveTemperature"
                                                Text="实时温度"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLiveTemperatureText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLiveTemperatureItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Grid.Column="1"
                                        MinHeight="170"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LiveFanRpm"
                                                Text="平均转速"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLiveFanRpmText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLiveFanItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Grid.Column="2"
                                        MinHeight="170"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LivePower"
                                                Text="实时功耗"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLivePowerText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLivePowerItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Grid.Column="3"
                                        MinHeight="170"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LiveVoltage"
                                                Text="平均电压"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLiveVoltageText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLiveVoltageItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Grid.Column="4"
                                        MinHeight="170"
                                        Padding="10,8"
                                        Background="#18FFFFFF"
                                        BorderBrush="#30FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <StackPanel Spacing="2">
                                            <TextBlock
                                                Foreground="#CFFAFE"
                                                FontSize="11"
                                                local:Localization.Key="Hero.LiveCurrent"
                                                Text="总电流"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLiveCurrentText"
                                                Foreground="White"
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                            <TextBlock
                                                x:Name="HeroLiveCurrentItemsText"
                                                Foreground="#BDEAF4"
                                                FontSize="11"
                                                Text="--"
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                            <Border
                                Grid.Column="1"
                                x:Name="HeroStatusCard"
                                Width="340"
                                MinWidth="320"
                                Padding="18,14"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="#1FFFFFFF"
                                BorderBrush="#38FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        Foreground="#D8F7FF"
                                        local:Localization.Key="Hero.Target"
                                        Text="当前目标" />
                                    <TextBlock
                                        x:Name="CurrentTargetText"
