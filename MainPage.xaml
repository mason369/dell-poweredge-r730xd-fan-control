                                                            Grid.Row="1"
                                                            Style="{StaticResource MutedTextStyle}"
                                                            Text="{Binding Subtitle}" />
                                                        <TextBox
                                                            Grid.Row="2"
                                                            AcceptsReturn="True"
                                                            Header="预设说明"
                                                            local:Localization.Key="Preset.Description"
                                                            MaxLength="180"
                                                            MaxHeight="76"
                                                            MinHeight="64"
                                                            Text="{Binding EditableDetail, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            TextWrapping="Wrap" />
                                                    </Grid>

                                                    <NumberBox
                                                        Grid.Row="2"
                                                        Header="%"
                                                        IsEnabled="{Binding CanEditPercent}"
                                                        Maximum="100"
                                                        Minimum="0"
                                                        SmallChange="1"
                                                        SpinButtonPlacementMode="Compact"
                                                        Value="{Binding Percent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                    <StackPanel Grid.Row="3" Spacing="6">
