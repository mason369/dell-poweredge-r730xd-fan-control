<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="DellR730xdFanControlCenter.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:DellR730xdFanControlCenter"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnPageLoaded"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
    </Page.Resources>

    <NavigationView
        x:Name="ShellNavigation"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        PaneDisplayMode="LeftCompact"
        SelectionChanged="OnNavigationSelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem
                local:Localization.Key="Nav.Overview"
                Content="总览"
                IsSelected="True"
                Tag="Overview">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                local:Localization.Key="Nav.Control"
                Content="风扇控制"
                Tag="Control">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE9CA;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                local:Localization.Key="Nav.Sensors"
                Content="传感器"
                Tag="Sensors">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE7B5;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                local:Localization.Key="Nav.Settings"
                Content="设置"
                Tag="Settings">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <InfoBar
                x:Name="StatusInfoBar"
                Margin="24,12,24,0"
                IsClosable="True"
                IsOpen="False"
                Severity="Informational" />

            <ScrollViewer
                x:Name="ContentScrollViewer"
                Grid.Row="1"
                HorizontalAlignment="Stretch"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled">
                <StackPanel
                    Width="{Binding ViewportWidth, ElementName=ContentScrollViewer}"
                    HorizontalAlignment="Left"
                    Padding="24"
                    Spacing="18">
                    <Border
                        MinHeight="156"
                        Padding="24"
                        CornerRadius="8">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0B1020" Offset="0" />
                                <GradientStop Color="#104E64" Offset="0.42" />
                                <GradientStop Color="#0EA5A4" Offset="0.72" />
                                <GradientStop Color="#2F80ED" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.ColumnSpan="2"
                                Height="1"
                                Margin="0,0,0,4"
                                VerticalAlignment="Bottom"
                                Background="#35FFFFFF" />
                            <Border
                                Grid.ColumnSpan="2"
                                Width="520"
                                Height="156"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Opacity="0.28">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00FFFFFF" Offset="0" />
                                        <GradientStop Color="#60FFFFFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <StackPanel Spacing="8">
                                <TextBlock
                                    Foreground="White"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    local:Localization.Key="Hero.AppName"
                                    Text="Dell R730xd iDRAC 风扇控制中心" />
                                <TextBlock
                                    Foreground="White"
                                    FontSize="32"
                                    FontWeight="SemiBold"
                                    local:Localization.Key="Hero.Title"
                                    Text="R730XD 智控风扇中心" />
                                <TextBlock
                                    MaxWidth="780"
                                    Foreground="#DDEFFF"
                                    local:Localization.Key="Hero.Subtitle"
                                    Text="监控 BMC 传感器，控制全部或单个风扇，支持 Dell 自动模式与软件恒温策略。" />
                            </StackPanel>
                            <Border
                                Grid.Column="1"
                                MinWidth="230"
                                Padding="18,14"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="#1FFFFFFF"
                                BorderBrush="#38FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8">
                                <StackPanel Spacing="8">
                                    <TextBlock
                                        Foreground="#D8F7FF"
                                        local:Localization.Key="Hero.Target"
                                        Text="当前目标" />
                                    <TextBlock
                                        x:Name="CurrentTargetText"
                                        Foreground="White"
                                        FontSize="20"
                                        FontWeight="SemiBold"
                                        Text="192.168.1.73" />
                                    <TextBlock
                                        x:Name="ConnectionStateText"
                                        Foreground="#CFFAFE"
                                        Text="未连接" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid x:Name="OverviewView">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Margin="0,0,12,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    local:Localization.Key="Overview.MaxCpuTemp"
                                    Style="{StaticResource MutedTextStyle}"
                                    Text="最高 CPU 温度" />
                                <TextBlock x:Name="CpuTemperatureText" Style="{StaticResource MetricValueStyle}" Text="-- °C" />
                                <TextBlock
                                    local:Localization.Key="Overview.FromSdrTemp"
                                    Style="{StaticResource MutedTextStyle}"
                                    Text="来自 SDR 温度传感器" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Margin="6,0,6,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    local:Localization.Key="Overview.FanStatus"
                                    Style="{StaticResource MutedTextStyle}"
                                    Text="风扇状态" />
                                <TextBlock x:Name="FanSummaryText" Style="{StaticResource MetricValueStyle}" Text="6 个风扇" />
                                <TextBlock x:Name="FanRpmSummaryText" Style="{StaticResource MutedTextStyle}" Text="等待刷新" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Margin="12,0,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock
                                    local:Localization.Key="Overview.Mode"
                                    Style="{StaticResource MutedTextStyle}"
                                    Text="控制模式" />
                                <TextBlock x:Name="ModeSummaryText" Style="{StaticResource MetricValueStyle}" Text="待机" />
                                <TextBlock x:Name="AutoPolicySummaryText" Style="{StaticResource MutedTextStyle}" Text="软件自动策略未运行" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            local:Localization.Key="Overview.VisualizationBoard"
                                            Style="{StaticResource SectionTitleStyle}"
                                            Text="交互式数据可视化" />
                                        <TextBlock
                                            local:Localization.Key="Overview.VisualizationHelp"
                                            Style="{StaticResource MutedTextStyle}"
                                            Text="总览趋势、单项硬件、按硬件类型和健康状态的交互图表。" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="VisualizationStateText"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="等待图表加载" />
                                </Grid>
                                <WebView2
                                    x:Name="VisualizationWebView"
                                    MinHeight="760"
                                    Loaded="OnVisualizationWebViewLoaded"
                                    NavigationCompleted="OnVisualizationNavigationCompleted" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            local:Localization.Key="Overview.TempBoard"
                                            Style="{StaticResource SectionTitleStyle}"
                                            Text="温度大看板" />
                                        <TextBlock
                                            local:Localization.Key="Overview.TempBoardHelp"
                                            Style="{StaticResource MutedTextStyle}"
                                            Text="逐项显示 BMC SDR 中的每一个温度传感器。" />
                                    </StackPanel>
                                    <TextBlock
                                        x:Name="LastPollText"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="等待轮询" />
                                </Grid>
                                <GridView
                                    MaxHeight="300"
                                    IsItemClickEnabled="False"
                                    ItemsSource="{x:Bind TemperatureTiles, Mode=OneWay}"
                                    SelectionMode="None">
                                    <GridView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsWrapGrid Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </GridView.ItemsPanel>
                                    <GridView.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Width="220"
                                                MinHeight="122"
                                                Margin="0,0,10,10"
                                                Padding="16"
                                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                                <StackPanel Spacing="6">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock FontSize="32" FontWeight="SemiBold" Text="{Binding Value}" />
                                                        <TextBlock VerticalAlignment="Bottom" Style="{StaticResource MutedTextStyle}" Text="{Binding Unit}" />
                                                    </StackPanel>
                                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding Subtitle}" />
                                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding Status}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </GridView.ItemTemplate>
                                </GridView>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="3" Grid.ColumnSpan="3" Margin="0,18,0,0" ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock
                                        local:Localization.Key="Overview.FanBoard"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="风扇 RPM 看板" />
                                    <GridView
                                        MaxHeight="260"
                                        IsItemClickEnabled="False"
                                        ItemsSource="{x:Bind FanTiles, Mode=OneWay}"
                                        SelectionMode="None">
                                        <GridView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsWrapGrid Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </GridView.ItemsPanel>
                                        <GridView.ItemTemplate>
                                            <DataTemplate>
                                                <Border
                                                    Width="180"
                                                    MinHeight="106"
                                                    Margin="0,0,10,10"
                                                    Padding="14"
                                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding Value}" />
                                                            <TextBlock VerticalAlignment="Bottom" Style="{StaticResource MutedTextStyle}" Text="{Binding Unit}" />
                                                        </StackPanel>
                                                        <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding Status}" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                                <StackPanel Spacing="12">
                                    <TextBlock
                                        local:Localization.Key="Overview.PowerHealth"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="功耗与状态" />
                                    <ListView
                                        MaxHeight="260"
                                        ItemsSource="{x:Bind PowerTiles, Mode=OneWay}"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="0,6" ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                        <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding Status}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Value}" />
                                                        <TextBlock VerticalAlignment="Bottom" Style="{StaticResource MutedTextStyle}" Text="{Binding Unit}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="4" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="14">
                                    <TextBlock
                                        local:Localization.Key="Overview.QuickActions"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="快速操作" />
                                    <CommandBar DefaultLabelPosition="Right" IsOpen="False">
                                        <AppBarButton
                                            Click="OnTestConnectionClick"
                                            Icon="Contact"
                                            local:Localization.Key="Action.Connect"
                                            Label="连接" />
                                        <AppBarButton
                                            Click="OnRefreshSensorsClick"
                                            Icon="Refresh"
                                            local:Localization.Key="Action.RefreshSensors"
                                            Label="刷新传感器" />
                                        <AppBarButton
                                            Click="OnRestoreDefaultClick"
                                            Icon="Sync"
                                            local:Localization.Key="Action.Restore10"
                                            Label="还原 10%" />
                                        <AppBarButton
                                            Click="OnVisitIdracClick"
                                            Icon="World"
                                            local:Localization.Key="Action.OpenIdrac"
                                            Label="打开 iDRAC" />
                                    </CommandBar>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock
                                        local:Localization.Key="Overview.AllFans"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="全部风扇" />
                                    <Slider
                                        x:Name="AllFanSlider"
                                        Maximum="100"
                                        Minimum="0"
                                        StepFrequency="1"
                                        ValueChanged="OnAllFanSliderChanged" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <NumberBox
                                            x:Name="AllFanPercentBox"
                                            Grid.Column="1"
                                            Maximum="100"
                                            Minimum="0"
                                            SmallChange="1"
                                            SpinButtonPlacementMode="Inline"
                                            ValueChanged="OnAllFanNumberChanged" />
                                        <Button Grid.Column="2" Click="OnSetAllFansClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                                <TextBlock local:Localization.Key="Action.Apply" Text="应用" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="5" Grid.ColumnSpan="3" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="10">
                                    <TextBlock
                                        local:Localization.Key="Control.SmartAutoPolicy"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="软件恒温策略" />
                                    <TextBlock
                                        local:Localization.Key="Control.SmartAutoHelp"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="按 CPU 温度线性调整全部风扇；达到紧急温度时切回 Dell 自动模式。" />
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="StartAutoButton" Click="OnStartAutoPolicyClick">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="14" Glyph="&#xE768;" />
                                                <TextBlock local:Localization.Key="Action.StartAuto" Text="启动自动" />
                                            </StackPanel>
                                        </Button>
                                        <Button
                                            x:Name="StopAutoButton"
                                            Grid.Column="1"
                                            Click="OnStopAutoPolicyClick"
                                            IsEnabled="False">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon FontSize="14" Glyph="&#xE71A;" />
                                                <TextBlock local:Localization.Key="Action.Stop" Text="停止" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock
                                        local:Localization.Key="Overview.RecentLog"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="最新日志" />
                                    <ListView
                                        MaxHeight="220"
                                        ItemsSource="{x:Bind Logs, Mode=OneWay}"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="64" />
                                                        <ColumnDefinition Width="72" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding DisplayTime}" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Level}" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Message}" TextWrapping="Wrap" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="ControlView" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="16">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock
                                            local:Localization.Key="Control.Presets"
                                            Style="{StaticResource SectionTitleStyle}"
                                            Text="预设模式" />
                                        <TextBlock
                                            x:Name="ControlCurrentModeText"
                                            Style="{StaticResource MutedTextStyle}"
                                            Text="当前模式：待机" />
                                    </StackPanel>
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        local:Localization.Key="Control.PresetRules"
                                        Style="{StaticResource MutedTextStyle}"
                                        Text="预设规则" />
                                </Grid>

                                <ListView ItemsSource="{x:Bind Presets, Mode=OneWay}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,8" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="150" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                        <TextBlock Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Text="{Binding CurrentMarker}" />
                                                    </StackPanel>
                                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding Subtitle}" />
                                                </StackPanel>
                                                <NumberBox
                                                    Grid.Column="1"
                                                    IsEnabled="{Binding CanEditPercent}"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    SmallChange="1"
                                                    SpinButtonPlacementMode="Inline"
                                                    Value="{Binding Percent, Mode=TwoWay}" />
                                                <Button
                                                    Grid.Column="2"
                                                    Click="OnApplyPresetClick"
                                                    Tag="{Binding Id}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="14" Glyph="&#xE768;" />
                                                        <TextBlock Text="{Binding ApplyButtonLabel}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    Grid.Column="3"
                                                    Click="OnSavePresetClick"
                                                    Tag="{Binding Id}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                                        <TextBlock Text="{Binding SaveButtonLabel}" />
                                                    </StackPanel>
                                                </Button>
                                                <Button
                                                    Grid.Column="4"
                                                    Click="OnDeletePresetClick"
                                                    IsEnabled="{Binding CanDelete}"
                                                    Tag="{Binding Id}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                                        <TextBlock Text="{Binding DeleteButtonLabel}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="NewPresetNameBox"
                                        local:Localization.Key="Preset.Name"
                                        Header="预设名称"
                                        PlaceholderText="例如：夜间静音" />
                                    <NumberBox
                                        x:Name="NewPresetPercentBox"
                                        Grid.Column="1"
                                        local:Localization.Key="Preset.Percent"
                                        Header="风扇百分比"
                                        Maximum="100"
                                        Minimum="0"
                                        SmallChange="1"
                                        SpinButtonPlacementMode="Inline"
                                        Value="10" />
                                    <Button
                                        Grid.Column="2"
                                        VerticalAlignment="Bottom"
                                        Click="OnAddPresetClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE710;" />
                                            <TextBlock local:Localization.Key="Control.AddPreset" Text="添加手动预设" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="14">
                                <TextBlock
                                    local:Localization.Key="Control.IndividualFans"
                                    Style="{StaticResource SectionTitleStyle}"
                                    Text="单风扇控制" />
                                <InfoBar
                                    x:Name="IndividualFanInfoBar"
                                    IsOpen="True"
                                    Severity="Warning"
                                    Message="单风扇 raw target 当前未启用。需要使用单风扇控制时，请先在设置中开启并保存。" />
                                <TextBlock
                                    local:Localization.Key="Control.IndividualHelp"
                                    Style="{StaticResource MutedTextStyle}"
                                    Text="启用后会发送 Dell OEM raw target byte：Fan 1-6 映射为 0x00-0x05。若行为不符合预期，请立即恢复 Dell 自动模式。" />
                                <ListView ItemsSource="{x:Bind FanChannels, Mode=OneWay}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,8" ColumnSpacing="14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="140" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="120" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                    <TextBlock Style="{StaticResource MutedTextStyle}" Text="{Binding ChineseName}" />
                                                </StackPanel>
                                                <Slider
                                                    Grid.Column="1"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    StepFrequency="1"
                                                    Value="{Binding Percent, Mode=TwoWay}" />
                                                <NumberBox
                                                    Grid.Column="2"
                                                    Maximum="100"
                                                    Minimum="0"
                                                    SmallChange="1"
                                                    SpinButtonPlacementMode="Inline"
                                                    Value="{Binding Percent, Mode=TwoWay}" />
                                                <Button
                                                    Grid.Column="3"
                                                    Click="OnSetSingleFanClick"
                                                    Tag="{Binding Index}">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                                        <TextBlock Text="{Binding SetButtonLabel}" />
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Margin="0,18,0,0" Style="{StaticResource CardBorderStyle}">
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="6">
                                    <TextBlock local:Localization.Key="Control.TargetTemp" Text="目标温度" />
                                    <NumberBox x:Name="TargetTempBox" Maximum="95" Minimum="30" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock local:Localization.Key="Control.HighTemp" Text="高温" />
                                    <NumberBox x:Name="HighTempBox" Maximum="100" Minimum="40" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="6">
                                    <TextBlock local:Localization.Key="Control.EmergencyAuto" Text="紧急自动" />
                                    <NumberBox x:Name="EmergencyTempBox" Maximum="105" Minimum="45" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="6">
                                    <TextBlock local:Localization.Key="Control.PollSeconds" Text="轮询秒数" />
                                    <NumberBox x:Name="SensorRefreshSecondsBox" Maximum="300" Minimum="1" SpinButtonPlacementMode="Inline" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="SensorsView" Visibility="Collapsed">
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        local:Localization.Key="Sensors.Title"
                                        Style="{StaticResource SectionTitleStyle}"
                                        Text="BMC 传感器" />
                                    <Button Grid.Column="1" Click="OnRefreshSensorsClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE72C;" />
                                            <TextBlock local:Localization.Key="Action.Refresh" Text="刷新" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <ListView
                                    MaxHeight="640"
                                    ItemsSource="{x:Bind Sensors, Mode=OneWay}"
                                    SelectionMode="None">
                                    <ListView.Header>
                                        <Grid Padding="12,6" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                local:Localization.Key="Sensors.Key"
                                                FontWeight="SemiBold"
                                                Text="传感器" />
                                            <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="ID" />
                                            <TextBlock
                                                Grid.Column="2"
                                                local:Localization.Key="Sensors.Entity"
                                                FontWeight="SemiBold"
                                                Text="实体" />
                                            <TextBlock
                                                Grid.Column="3"
                                                local:Localization.Key="Sensors.Value"
                                                FontWeight="SemiBold"
                                                Text="读数" />
                                            <TextBlock
                                                Grid.Column="4"
                                                local:Localization.Key="Sensors.Unit"
                                                FontWeight="SemiBold"
                                                Text="单位" />
                                            <TextBlock
                                                Grid.Column="5"
                                                local:Localization.Key="Sensors.Status"
                                                FontWeight="SemiBold"
                                                Text="状态" />
                                        </Grid>
                                    </ListView.Header>
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="12,7" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Key}" />
                                                <TextBlock Grid.Column="1" Text="{Binding SensorId}" />
                                                <TextBlock Grid.Column="2" Text="{Binding Entity}" />
                                                <TextBlock Grid.Column="3" Text="{Binding Value}" />
                                                <TextBlock Grid.Column="4" Text="{Binding Unit}" />
                                                <TextBlock Grid.Column="5" Text="{Binding Status}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="SettingsView" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Margin="0,0,9,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    local:Localization.Key="Settings.Connection"
                                    Style="{StaticResource SectionTitleStyle}"
                                    Text="iDRAC 连接" />
                                <TextBox x:Name="HostBox" Header="BMC/iDRAC IP" />
                                <TextBox
                                    x:Name="UserNameBox"
                                    local:Localization.Key="Settings.UserName"
                                    Header="用户名" />
                                <PasswordBox
                                    x:Name="PasswordBox"
                                    local:Localization.Key="Settings.Password"
                                    Header="密码"
                                    PasswordRevealMode="Peek" />
                                <ToggleSwitch
                                    x:Name="RememberPasswordSwitch"
                                    local:Localization.Key="Settings.RememberPassword"
                                    Header="使用 DPAPI 保存密码" />
                                <TextBox
                                    x:Name="IpmiToolPathBox"
                                    local:Localization.Key="Settings.BundledIpmiPath"
                                    Header="内置 ipmitool 路径"
                                    IsReadOnly="True" />
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Button Click="OnSaveSettingsClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE74E;" />
                                            <TextBlock local:Localization.Key="Action.Save" Text="保存设置" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Click="OnTestConnectionClick">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE8FB;" />
                                            <TextBlock local:Localization.Key="Action.Connect" Text="连接" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Margin="9,0,0,0" Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <TextBlock
                                    local:Localization.Key="Settings.Application"
                                    Style="{StaticResource SectionTitleStyle}"
                                    Text="应用设置" />
                                <ToggleSwitch
                                    x:Name="MinimizeToTraySwitch"
                                    local:Localization.Key="Settings.MinimizeToTray"
                                    Header="点击关闭时最小化到托盘" />
                                <ToggleSwitch
                                    x:Name="IndividualFanSwitch"
                                    local:Localization.Key="Settings.EnableIndividualFanTargets"
                                    Header="启用单风扇 raw target"
                                    Toggled="OnIndividualFanSwitchToggled" />
                                <NumberBox
                                    x:Name="FanCountBox"
                                    local:Localization.Key="Settings.FanCount"
                                    Header="风扇数量"
                                    Maximum="6"
                                    Minimum="1"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="CommandTimeoutBox"
                                    local:Localization.Key="Settings.CommandTimeout"
                                    Header="命令超时秒数"
                                    Maximum="180"
                                    Minimum="5"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="AutoMinFanBox"
                                    local:Localization.Key="Settings.AutoMinFan"
                                    Header="自动策略最小风扇百分比"
                                    Maximum="100"
                                    Minimum="0"
                                    SpinButtonPlacementMode="Inline" />
                                <NumberBox
                                    x:Name="AutoMaxFanBox"
                                    local:Localization.Key="Settings.AutoMaxFan"
                                    Header="自动策略最大风扇百分比"
                                    Maximum="100"
                                    Minimum="0"
                                    SpinButtonPlacementMode="Inline" />
                                <ComboBox
                                    x:Name="ThemeComboBox"
                                    local:Localization.Key="Settings.Theme"
                                    Header="主题">
                                    <ComboBoxItem
                                        local:Localization.Key="Theme.System"
                                        Content="跟随系统"
                                        Tag="Default" />
                                    <ComboBoxItem
                                        local:Localization.Key="Theme.Light"
                                        Content="浅色"
                                        Tag="Light" />
                                    <ComboBoxItem
                                        local:Localization.Key="Theme.Dark"
                                        Content="深色"
                                        Tag="Dark" />
                                </ComboBox>
                                <ComboBox
                                    x:Name="LanguageComboBox"
                                    local:Localization.Key="Settings.Language"
                                    Header="界面语言"
                                    SelectionChanged="OnLanguageSelectionChanged">
                                    <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                                    <ComboBoxItem Content="English" Tag="en-US" />
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </NavigationView>
</Page>
